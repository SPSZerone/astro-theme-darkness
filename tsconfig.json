{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "astro",
    "paths": {
      "@styles/*": ["./src/styles/*"],
      "@/*": ["./src/*"],
      "@spscommon/*": ["./sps/common/src/*"],
      "@spslocal/*": ["./sps/local/src/*"]
    }
  },
}
